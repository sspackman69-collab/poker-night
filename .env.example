# Copy to .env for local overrides (not needed for a default single-service deploy).

# Port the server listens on. Most hosts inject their own PORT and override this.
PORT=3001

# Browser origin allowed for CORS. Default '*' is fine for single-service
# deploys (client served from the same origin). Set this only if you host the
# client separately, e.g. CLIENT_ORIGIN=https://poker.example.com
CLIENT_ORIGIN=*

# Build-time ONLY, and ONLY if the client is hosted separately from the API.
# Leave unset for single-service deploys (the client connects to its own origin).
# VITE_SERVER_URL=https://your-api.example.com
